# Prod idle tuning for single-node (demo-idle profile). Merge into ispf-server.env
# Docs: docs/DEMOSTANDS.md (production, idle, edge profiles), ADR-0033
# Secrets (DB password, AI keys) are NOT listed here — preserved from existing env.

# Metrics probe: off at boot; enable only from System → Metrics → Load diagnostics toggle
ISPF_PLATFORM_METRICS_PROBE_ENABLED=false

# Lighter persistence (no Scylla writer pools on idle prod)
ISPF_VARIABLE_HISTORY_STORE=jdbc
ISPF_EVENT_JOURNAL_STORE=jdbc
ISPF_VARIABLE_HISTORY_MIN_INTERVAL_MS=5000
ISPF_VARIABLE_HISTORY_FLUSH_INTERVAL_MS=500
ISPF_EVENT_JOURNAL_FLUSH_INTERVAL_MS=200
ISPF_VARIABLE_HISTORY_WRITER_THREADS=2
ISPF_EVENT_JOURNAL_WRITER_THREADS=2
ISPF_EVENT_JOURNAL_WRITER_THREADS_MIN=1
ISPF_EVENT_JOURNAL_WRITER_THREADS_MAX=4
ISPF_VARIABLE_HISTORY_WRITER_THREADS_MIN=1
ISPF_VARIABLE_HISTORY_WRITER_THREADS_MAX=4
ISPF_EVENT_JOURNAL_ELASTIC_WRITER=false
ISPF_VARIABLE_HISTORY_ELASTIC_WRITER_ENABLED=false

# Smaller elastic pools (fixed size on idle single-node — no elastic scale churn)
ISPF_OBJECT_CHANGE_ELASTIC_WORKERS=false
ISPF_OBJECT_CHANGE_TELEMETRY_WORKERS=2
ISPF_OBJECT_CHANGE_TELEMETRY_WORKERS_MIN=1
ISPF_OBJECT_CHANGE_TELEMETRY_WORKERS_MAX=2
ISPF_OBJECT_CHANGE_AUTOMATION_WORKERS=2
ISPF_OBJECT_CHANGE_AUTOMATION_WORKERS_MIN=1
ISPF_OBJECT_CHANGE_AUTOMATION_WORKERS_MAX=2
ISPF_OBJECT_CHANGE_ELASTIC_SCALE_CHECK_MS=2000

# L3 telemetry ingress: 1-2 workers instead of elastic 4-32 (ADR-0026 load-test defaults)
ISPF_RUNTIME_TELEMETRY_INGRESS_ELASTIC_WORKERS=false
ISPF_RUNTIME_TELEMETRY_INGRESS_WORKERS_MIN=1
ISPF_RUNTIME_TELEMETRY_INGRESS_WORKERS_MAX=2
ISPF_RUNTIME_TELEMETRY_COALESCE_SCHEDULER_ELASTIC=false
ISPF_RUNTIME_TELEMETRY_COALESCE_SCHEDULER_THREADS=1

# Binding async CEL: fixed small pool
ISPF_BINDING_ASYNC_ELASTIC=false
ISPF_BINDING_ASYNC_THREADS=2
ISPF_BINDING_ASYNC_THREADS_MIN=1
ISPF_BINDING_ASYNC_THREADS_MAX=2

# Driver I/O + ingress buffer (L1/L2)
ISPF_DRIVER_SCHEDULER_THREADS_ELASTIC=false
ISPF_DRIVER_SCHEDULER_THREADS=2
ISPF_DRIVER_IO_THREADS_ELASTIC=false
ISPF_DRIVER_IO_THREADS=2
ISPF_DRIVER_INGRESS_BUFFER_ELASTIC=false
ISPF_DRIVER_INGRESS_BUFFER_THREADS=1

ISPF_DRIVER_IO_THREADS_MIN=1
ISPF_DRIVER_IO_THREADS_MAX=4
ISPF_DRIVER_SCHEDULER_THREADS_MIN=1
ISPF_DRIVER_SCHEDULER_THREADS_MAX=4
ISPF_MQTT_GATEWAY_INGRESS_DISPATCH_THREADS=2
ISPF_RUNTIME_TELEMETRY_COALESCE_MS=1000

# Optional: disable job consumer on single idle node (no async report queue needed)
ISPF_CLUSTER_JOB_CONSUMER_ENABLED=false

# Tomcat
SERVER_TOMCAT_THREADS_MAX=50

# Redis: keep if used for ACL/cache; set false if not needed
# ISPF_REDIS_ENABLED=false
