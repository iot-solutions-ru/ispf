{
  "realm": "ispf",
  "enabled": true,
  "roles": {
    "realm": [
      { "name": "admin" },
      { "name": "operator" }
    ]
  },
  "clients": [
    {
      "clientId": "ispf-web-console",
      "name": "ISPF Web Console",
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*",
        "http://localhost:8080/*"
      ],
      "webOrigins": ["+"]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Platform",
      "lastName": "Admin",
      "credentials": [{ "type": "password", "value": "admin", "temporary": false }],
      "realmRoles": ["admin"]
    },
    {
      "username": "operator",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Platform",
      "lastName": "Operator",
      "credentials": [{ "type": "password", "value": "operator", "temporary": false }],
      "realmRoles": ["operator"]
    }
  ]
}
