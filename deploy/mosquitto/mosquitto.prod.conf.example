# Production MQTT broker example — TLS + authentication.
# Copy to mosquitto.conf and set paths/credentials before exposing beyond lab.

listener 8883
protocol mqtt
cafile /etc/mosquitto/certs/ca.crt
certfile /etc/mosquitto/certs/server.crt
keyfile /etc/mosquitto/certs/server.key
require_certificate false

allow_anonymous false
password_file /etc/mosquitto/passwd
persistence true
persistence_location /var/lib/mosquitto/

# ISPF driver config: ispf.mqtt.broker-url=ssl://broker.example.com:8883
