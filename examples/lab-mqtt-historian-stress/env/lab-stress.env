# Anonymized lab template — copy to ~/ispf on your hosts and replace placeholders.
# Do not put real hosts, SSH users, or passwords in git. See local/README.md.

ISPF_LAB_DB_HOST=198.51.100.10
ISPF_LAB_HTTP_BIND=0.0.0.0

ISPF_MQTT_BROKER_HOST=198.51.100.10
ISPF_MQTT_BROKER_PORT=1883

ISPF_JAVA_OPTS="-Xms12g -Xmx28g -XX:+UseG1GC -XX:MaxGCPauseMillis=100 -XX:+AlwaysPreTouch"

ISPF_EVENT_JOURNAL_ENABLED=true
ISPF_EVENT_JOURNAL_WRITER_THREADS=24
ISPF_EVENT_JOURNAL_QUEUE_CAPACITY=5000000
ISPF_EVENT_JOURNAL_BATCH_SIZE=5000
ISPF_EVENT_JOURNAL_FLUSH_INTERVAL_MS=10
ISPF_EVENT_JOURNAL_RECENT_CACHE_SIZE=500

# Scylla/CQL write path — PARALLEL_BATCHES is the ceiling; elastic ramps min→max under queue load
ISPF_EVENT_JOURNAL_CASSANDRA_PARTITION_BATCH=200
ISPF_EVENT_JOURNAL_CASSANDRA_PARALLEL_BATCHES_MIN=1
ISPF_EVENT_JOURNAL_CASSANDRA_PARALLEL_BATCHES=64
ISPF_EVENT_JOURNAL_CASSANDRA_ELASTIC_PARALLEL=true
ISPF_EVENT_JOURNAL_CASSANDRA_PARALLEL_SCALE_UP=16
ISPF_EVENT_JOURNAL_CASSANDRA_GLOBAL_TABLE_ENABLED=false
ISPF_EVENT_JOURNAL_CASSANDRA_ASYNC_COUNTER_UPDATE=true

ISPF_OBJECT_CHANGE_ASYNC_ENABLED=false
ISPF_RUNTIME_TELEMETRY_INGRESS_QUEUE_ENABLED=true
ISPF_RUNTIME_TELEMETRY_INGRESS_QUEUE_COALESCE=false
ISPF_RUNTIME_TELEMETRY_COALESCE_ENABLED=false
ISPF_RUNTIME_TELEMETRY_FAST_HISTORIAN_PATH=true

ISPF_MQTT_GATEWAY_INGRESS_DISPATCH_ELASTIC=true
ISPF_MQTT_GATEWAY_INGRESS_DISPATCH_THREADS_MAX=32
ISPF_MQTT_GATEWAY_INGRESS_DISPATCH_COALESCE=false
ISPF_MQTT_GATEWAY_INGRESS_BYPASS_L3=true

# Historian (Scylla variable_samples) — align with event-journal stress tuning
ISPF_VARIABLE_HISTORY_MIN_INTERVAL_MS=0
ISPF_VARIABLE_HISTORY_WRITER_THREADS=32
ISPF_VARIABLE_HISTORY_QUEUE_CAPACITY=8000000
ISPF_VARIABLE_HISTORY_BATCH_SIZE=5000
ISPF_VARIABLE_HISTORY_FLUSH_INTERVAL_MS=10
ISPF_VARIABLE_HISTORY_CASSANDRA_PARTITION_BATCH=400
ISPF_VARIABLE_HISTORY_CASSANDRA_PARALLEL_BATCHES_MIN=4
ISPF_VARIABLE_HISTORY_CASSANDRA_PARALLEL_BATCHES=128
ISPF_VARIABLE_HISTORY_CASSANDRA_ELASTIC_PARALLEL=true
ISPF_VARIABLE_HISTORY_CASSANDRA_PARALLEL_SCALE_UP=32
ISPF_VARIABLE_HISTORY_WRITER_THREADS_MIN=8
ISPF_VARIABLE_HISTORY_WRITER_THREADS_MAX=48

# MQTT driver L0 FIFO defaults (server-wide; per-driver override via ingressCoalesceEnabled in driver config)
ISPF_DRIVER_MQTT_INGRESS_COALESCE=false
ISPF_DRIVER_MQTT_CALLBACK_THREADS=256
ISPF_DRIVER_MQTT_CALLBACK_QUEUE_CAPACITY=500000

# Legacy aliases for load-test scripts (optional explicit override via CALLBACK_THREADS= on CLI)
STRESS_CALLBACK_THREADS=
CALLBACK_QUEUE_CAPACITY=

# Sustained load: calibrate with AUTO_CALIBRATE; peak journal ~110k events/s on lab (16 dev, Scylla 20 SMP)
STRESS_SUSTAINED_RATE_PER_DEVICE=6800
STRESS_DEVICES=16
STRESS_RATE_PER_DEVICE=50000
STRESS_WARMUP=30
STRESS_PHASE=120

# emqtt-bench: fewer shards + CPU cap (see mqtt-emqtt-bench.sh EMQTT_CPU_LIMIT)
EMQTT_SHARD_MAX=4
EMQTT_CPU_LIMIT=1.5

# Historian benchmark: unique sampled_at per series (Scylla ms clustering)
ISPF_VARIABLE_HISTORY_BENCHMARK_SPREAD_SAMPLED_AT=true
ISPF_VARIABLE_HISTORY_OVERFLOW_COALESCE=false
