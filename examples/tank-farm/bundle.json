      "id": "tank_farm_sim",
      "sql": "CREATE TABLE IF NOT EXISTS tank_sim ( tank_code VARCHAR(32) PRIMARY KEY, tank_index INTEGER NOT NULL DEFAULT 1, level_mm DOUBLE PRECISION NOT NULL DEFAULT 5000, rate_mm_per_h DOUBLE PRECISION NOT NULL DEFAULT 0, rate_bias_mm_per_h DOUBLE PRECISION NOT NULL DEFAULT 0, max_level_mm DOUBLE PRECISION NOT NULL DEFAULT 10000, valve_open BOOLEAN NOT NULL DEFAULT false, updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW() ); CREATE TABLE IF NOT EXISTS hub_sim ( id INTEGER PRIMARY KEY, line_pressure_mpa DOUBLE PRECISION NOT NULL DEFAULT 0.82, line_flow_m3h DOUBLE PRECISION NOT NULL DEFAULT 1180, line_temp_c DOUBLE PRECISION NOT NULL DEFAULT 11, delta_pressure_mpa DOUBLE PRECISION NOT NULL DEFAULT 0.03, total_volume_m3 DOUBLE PRECISION NOT NULL DEFAULT 81000, updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW() ); INSERT INTO hub_sim (id) SELECT 1 WHERE NOT EXISTS (SELECT 1 FROM hub_sim WHERE id = 1); INSERT INTO tank_sim (tank_code, tank_index, level_mm, rate_mm_per_h, rate_bias_mm_per_h, max_level_mm) SELECT 'tank-11', 1, 1662, -430, -430, 10000 WHERE NOT EXISTS (SELECT 1 FROM tank_sim WHERE tank_code = 'tank-11'); INSERT INTO tank_sim (tank_code, tank_index, level_mm, rate_mm_per_h, rate_bias_mm_per_h, max_level_mm) SELECT 'tank-12', 2, 1667, 85, 85, 10000 WHERE NOT EXISTS (SELECT 1 FROM tank_sim WHERE tank_code = 'tank-12'); INSERT INTO tank_sim (tank_code, tank_index, level_mm, rate_mm_per_h, rate_bias_mm_per_h, max_level_mm) SELECT 'tank-13', 3, 1481, -120, -120, 10000 WHERE NOT EXISTS (SELECT 1 FROM tank_sim WHERE tank_code = 'tank-13'); INSERT INTO tank_sim (tank_code, tank_index, level_mm, rate_mm_per_h, rate_bias_mm_per_h, max_level_mm) SELECT 'tank-14', 4, 1597, 40, 40, 10000 WHERE NOT EXISTS (SELECT 1 FROM tank_sim WHERE tank_code = 'tank-14'); INSERT INTO tank_sim (tank_code, tank_index, level_mm, rate_mm_per_h, rate_bias_mm_per_h, max_level_mm) SELECT 'tank-15', 5, 1620, -210, -210, 10000 WHERE NOT EXISTS (SELECT 1 FROM tank_sim WHERE tank_code = 'tank-15'); INSERT INTO tank_sim (tank_code, tank_index, level_mm, rate_mm_per_h, rate_bias_mm_per_h, max_level_mm) SELECT 'tank-16', 6, 6352, 15, 15, 10000 WHERE NOT EXISTS (SELECT 1 FROM tank_sim WHERE tank_code = 'tank-16'); INSERT INTO tank_sim (tank_code, tank_index, level_mm, rate_mm_per_h, rate_bias_mm_per_h, max_level_mm) SELECT 'tank-17', 7, 1762, -55, -55, 10000 WHERE NOT EXISTS (SELECT 1 FROM tank_sim WHERE tank_code = 'tank-17'); INSERT INTO tank_sim (tank_code, tank_index, level_mm, rate_mm_per_h, rate_bias_mm_per_h, max_level_mm) SELECT 'tank-18', 8, 11726, 220, 220, 14000 WHERE NOT EXISTS (SELECT 1 FROM tank_sim WHERE tank_code = 'tank-18'); INSERT INTO tank_sim (tank_code, tank_index, level_mm, rate_mm_per_h, rate_bias_mm_per_h, max_level_mm) SELECT 'tank-19', 9, 1702, -180, -180, 14000 WHERE NOT EXISTS (SELECT 1 FROM tank_sim WHERE tank_code = 'tank-19');"
    }
