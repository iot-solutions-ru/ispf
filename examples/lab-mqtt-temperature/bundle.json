{
  "version": "1.0.0",
  "displayName": "MQTT Temperature Lab",
  "tablePrefix": "mlt_",
  "schemaName": "mqtt_temperature_lab",
  "metadata": {
    "taskVariant": "mqtt-temperature",
    "broker": "m5.wqtt.ru:11296"
  },
  "migrations": [
    {
      "id": "sensor_registry",
      "sql": "CREATE TABLE IF NOT EXISTS mlt_sensor (sensor_id VARCHAR(64) PRIMARY KEY, object_path VARCHAR(256) NOT NULL, display_name VARCHAR(128) NOT NULL, mqtt_topic VARCHAR(256) NOT NULL, latitude DOUBLE PRECISION NOT NULL, longitude DOUBLE PRECISION NOT NULL); INSERT INTO mlt_sensor (sensor_id, object_path, display_name, mqtt_topic, latitude, longitude) SELECT 'sensor-01', 'root.platform.devices.mqtt-lab.sensors.sensor-01', '1wire test 1', 'esp2/1wire_test1/temperature', 55.761, 37.638 WHERE NOT EXISTS (SELECT 1 FROM mlt_sensor WHERE sensor_id = 'sensor-01'); INSERT INTO mlt_sensor (sensor_id, object_path, display_name, mqtt_topic, latitude, longitude) SELECT 'sensor-02', 'root.platform.devices.mqtt-lab.sensors.sensor-02', '1wire test 2', 'esp2/1wire_test2/temperature', 55.765, 37.645 WHERE NOT EXISTS (SELECT 1 FROM mlt_sensor WHERE sensor_id = 'sensor-02'); INSERT INTO mlt_sensor (sensor_id, object_path, display_name, mqtt_topic, latitude, longitude) SELECT 'sensor-03', 'root.platform.devices.mqtt-lab.sensors.sensor-03', 'Aqua cold corner', 'esp1/aqua_coldcorner_water/temperature', 55.752, 37.621 WHERE NOT EXISTS (SELECT 1 FROM mlt_sensor WHERE sensor_id = 'sensor-03'); INSERT INTO mlt_sensor (sensor_id, object_path, display_name, mqtt_topic, latitude, longitude) SELECT 'sensor-04', 'root.platform.devices.mqtt-lab.sensors.sensor-04', 'Aqua island air', 'esp1/aqua_island_air/temperature', 55.748, 37.615 WHERE NOT EXISTS (SELECT 1 FROM mlt_sensor WHERE sensor_id = 'sensor-04'); CREATE TABLE IF NOT EXISTS mlt_poll_heartbeat (id INT PRIMARY KEY DEFAULT 1, last_tick TIMESTAMPTZ); INSERT INTO mlt_poll_heartbeat (id, last_tick) SELECT 1, NOW() WHERE NOT EXISTS (SELECT 1 FROM mlt_poll_heartbeat WHERE id = 1);"
    }
  ],
  "objects": [
    {
      "parentPath": "root.platform.devices",
      "name": "mqtt-lab",
      "type": "CUSTOM",
      "displayName": "MQTT Lab"
    },
    {
      "parentPath": "root.platform.devices.mqtt-lab",
      "name": "sensors",
