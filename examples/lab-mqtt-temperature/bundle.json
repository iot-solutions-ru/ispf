  "functions": [
    {
      "objectPath": "root.platform.devices.mqtt-lab.sensors.sensor-01",
      "functionName": "listSensors",
      "version": "1",
      "descriptor": {
        "inputSchema": { "name": "in", "fields": [] },
        "outputSchema": {
          "name": "out",
          "fields": [
            { "name": "error_code", "type": "STRING" },
            { "name": "error_message", "type": "STRING" },
            {
              "name": "rows",
              "type": "RECORD_LIST",
              "nestedSchema": {
                "name": "sensor_row",
                "fields": [
                  { "name": "sensorId", "type": "STRING", "description": "ID" },
                  { "name": "objectPath", "type": "STRING", "description": "Путь" },
                  { "name": "displayName", "type": "STRING", "description": "Датчик" },
                  { "name": "mqttTopic", "type": "STRING", "description": "MQTT топик" },
                  { "name": "latitude", "type": "DOUBLE", "description": "Широта" },
                  { "name": "longitude", "type": "DOUBLE", "description": "Долгота" }
                ]
              }
            }
          ]
        }
      },
      "source": {
        "type": "script",
        "body": "{\"steps\":[{\"type\":\"selectMany\",\"var\":\"sensors\",\"sql\":\"SELECT sensor_id, object_path, display_name, mqtt_topic, latitude, longitude FROM mlt_sensor ORDER BY sensor_id\"},{\"type\":\"map\",\"var\":\"rows\",\"source\":\"${sensors}\",\"fields\":{\"sensorId\":\"${item.sensor_id}\",\"objectPath\":\"${item.object_path}\",\"displayName\":\"${item.display_name}\",\"mqttTopic\":\"${item.mqtt_topic}\",\"latitude\":\"${item.latitude}\",\"longitude\":\"${item.longitude}\"}},{\"type\":\"return\",\"fields\":{\"error_code\":\"OK\",\"error_message\":\"\",\"rows\":\"${rows}\"}}]}"
      }
    },
    {
      "objectPath": "root.platform.devices.mqtt-lab.sensors.sensor-01",
      "functionName": "getSensorDetail",
      "version": "1",
      "descriptor": {
        "inputSchema": {
          "name": "in",
          "fields": [
            { "name": "sensorId", "type": "STRING" }
          ]
        },
        "outputSchema": {
          "name": "out",
          "fields": [
            { "name": "error_code", "type": "STRING" },
            { "name": "error_message", "type": "STRING" },
            { "name": "sensorId", "type": "STRING", "description": "ID" },
            { "name": "objectPath", "type": "STRING", "description": "Путь" },
            { "name": "displayName", "type": "STRING", "description": "Датчик" },
            { "name": "mqttTopic", "type": "STRING", "description": "MQTT топик" },
            { "name": "latitude", "type": "DOUBLE", "description": "Широта" },
            { "name": "longitude", "type": "DOUBLE", "description": "Долгота" }
          ]
        }
      },
      "source": {
        "type": "script",
        "body": "{\"steps\":[{\"type\":\"selectOne\",\"var\":\"sensor\",\"sql\":\"SELECT sensor_id, object_path, display_name, mqtt_topic, latitude, longitude FROM mlt_sensor WHERE sensor_id = ?\",\"params\":[\"${input.sensorId}\"]},{\"type\":\"failIfNull\",\"var\":\"sensor\",\"message\":\"Sensor not found\"},{\"type\":\"return\",\"fields\":{\"error_code\":\"OK\",\"error_message\":\"\",\"sensorId\":\"${sensor.sensor_id}\",\"objectPath\":\"${sensor.object_path}\",\"displayName\":\"${sensor.display_name}\",\"mqttTopic\":\"${sensor.mqtt_topic}\",\"latitude\":\"${sensor.latitude}\",\"longitude\":\"${sensor.longitude}\"}}]}"
      }
    },
    {
      "objectPath": "root.platform.devices.mqtt-lab.sensors.sensor-01",
      "functionName": "heartbeat",
      "version": "1",
      "descriptor": {
        "inputSchema": { "name": "in", "fields": [] },
        "outputSchema": {
          "name": "out",
          "fields": [
            { "name": "error_code", "type": "STRING" },
            { "name": "error_message", "type": "STRING" },
            { "name": "lastTick", "type": "STRING" }
          ]
        }
      },
      "source": {
        "type": "script",
        "body": "{\"steps\":[{\"type\":\"exec\",\"sql\":\"UPDATE mlt_poll_heartbeat SET last_tick = NOW() WHERE id = 1\"},{\"type\":\"selectOne\",\"var\":\"row\",\"sql\":\"SELECT last_tick::text AS last_tick FROM mlt_poll_heartbeat WHERE id = 1\"},{\"type\":\"return\",\"fields\":{\"error_code\":\"OK\",\"error_message\":\"\",\"lastTick\":\"${row.last_tick}\"}}]}"
      }
    }
  ],
  "schedules": [
    {
      "scheduleId": "mqtt-lab-heartbeat",
      "enabled": true,
      "intervalMs": 60000,
      "actionType": "invoke_function",
      "action": {
        "objectPath": "root.platform.devices.mqtt-lab.sensors.sensor-01",
        "functionName": "heartbeat"
      }
    }
  ],
  "alertRules": [
    {
      "name": "MQTT lab high temperature",
      "objectPath": "root.platform.devices.mqtt-lab.sensors.sensor-01",
      "watchVariable": "temperature",
      "conditionExpr": "self.temperature[\"value\"] > 30.0",
      "eventName": "mqttLabHighTemperature",
      "payloadVariable": "temperature",
      "enabled": true,
      "edgeTrigger": true,
      "delaySeconds": 0,
      "sustainWhileTrue": false
    }
  ],
  "events": [
    {
      "id": "mqttLabHighTemperature",
      "roles": ["admin", "operator"]
    }
  ],
  "dashboards": [
    {
      "path": "root.platform.dashboards.mqtt-lab-overview",
      "title": "MQTT Lab — обзор",
      "refreshIntervalMs": 3000,
      "layoutJson": "{\"columns\":12,\"rowHeight\":72,\"widgets\":[{\"id\":\"sensor-table\",\"type\":\"object-table\",\"title\":\"Датчики температуры\",\"x\":0,\"y\":0,\"w\":12,\"h\":4,\"parentPath\":\"root.platform.devices.mqtt-lab.sensors\",\"selectionKey\":\"sensor\",\"rowTargetDashboard\":\"root.platform.dashboards.mqtt-lab-detail\",\"rowOpenMode\":\"navigate\",\"columnsJson\":\"[{\\\"variable\\\":\\\"temperature\\\",\\\"label\\\":\\\"°C\\\",\\\"field\\\":\\\"value\\\",\\\"decimals\\\":2},{\\\"variable\\\":\\\"driverStatus\\\",\\\"label\\\":\\\"Драйвер\\\",\\\"field\\\":\\\"value\\\"},{\\\"variable\\\":\\\"threshold\\\",\\\"label\\\":\\\"Порог\\\",\\\"field\\\":\\\"value\\\"}]\"},{\"id\":\"sensor-map\",\"type\":\"map\",\"title\":\"Карта датчиков\",\"x\":0,\"y\":4,\"w\":12,\"h\":5,\"parentPath\":\"root.platform.devices.mqtt-lab.sensors\",\"latVariable\":\"coordinates\",\"latField\":\"latitude\",\"lonField\":\"longitude\",\"labelVariable\":\"sensorLabel\",\"centerLat\":55.755,\"centerLon\":37.62,\"zoom\":11,\"selectionKey\":\"sensor\",\"rowTargetDashboard\":\"root.platform.dashboards.mqtt-lab-detail\",\"rowOpenMode\":\"navigate\"},{\"id\":\"events\",\"type\":\"event-feed\",\"title\":\"Тревоги\",\"x\":0,\"y\":9,\"w\":12,\"h\":3,\"objectPath\":\"root.platform.devices.mqtt-lab.sensors.sensor-01\",\"eventNamesJson\":\"[\\\"mqttLabHighTemperature\\\",\\\"thresholdExceeded\\\"]\",\"maxItems\":15}]}"
    },
    {
      "path": "root.platform.dashboards.mqtt-lab-detail",
      "title": "MQTT Lab — датчик",
      "refreshIntervalMs": 2000,
      "layoutJson": "{\"columns\":12,\"rowHeight\":72,\"widgets\":[{\"id\":\"temp-value\",\"type\":\"value\",\"title\":\"Температура\",\"x\":0,\"y\":0,\"w\":4,\"h\":2,\"selectionKey\":\"sensor\",\"variableName\":\"temperature\",\"valueField\":\"value\",\"decimals\":2,\"unit\":\"°C\"},{\"id\":\"threshold-value\",\"type\":\"value\",\"title\":\"Порог тревоги\",\"x\":4,\"y\":0,\"w\":4,\"h\":2,\"selectionKey\":\"sensor\",\"variableName\":\"threshold\",\"valueField\":\"value\",\"decimals\":1,\"unit\":\"°C\"},{\"id\":\"driver-status\",\"type\":\"indicator\",\"title\":\"Драйвер\",\"x\":8,\"y\":0,\"w\":4,\"h\":2,\"selectionKey\":\"sensor\",\"variableName\":\"driverStatus\",\"valueField\":\"value\",\"trueLabel\":\"RUNNING\",\"falseLabel\":\"STOPPED\",\"trueColor\":\"#3fb950\",\"falseColor\":\"#8b949e\"},{\"id\":\"temp-chart\",\"type\":\"chart\",\"title\":\"История температуры\",\"x\":0,\"y\":2,\"w\":8,\"h\":5,\"selectionKey\":\"sensor\",\"variableName\":\"temperature\",\"valueField\":\"value\",\"chartStyle\":\"line\",\"maxPoints\":120,\"historyRange\":\"live\",\"color\":\"#2f81f7\",\"decimals\":2},{\"id\":\"alarm-indicator\",\"type\":\"indicator\",\"title\":\"Тревога\",\"x\":8,\"y\":2,\"w\":4,\"h\":2,\"selectionKey\":\"sensor\",\"variableName\":\"alarmActive\",\"valueField\":\"value\",\"trueLabel\":\"Активна\",\"falseLabel\":\"Норма\",\"trueColor\":\"#f85149\",\"falseColor\":\"#3fb950\"},{\"id\":\"set-temp\",\"type\":\"variable-editor\",\"title\":\"Задать температуру (локально)\",\"x\":8,\"y\":4,\"w\":4,\"h\":3,\"selectionKey\":\"sensor\",\"variablesJson\":\"[\\\"temperature\\\"]\"},{\"id\":\"ack-alarm\",\"type\":\"function-form\",\"title\":\"Квитировать тревогу\",\"x\":8,\"y\":7,\"w\":4,\"h\":2,\"selectionKey\":\"sensor\",\"functionName\":\"acknowledgeAlarm\",\"buttonLabel\":\"Квитировать\",\"fieldsJson\":\"[]\"}]}"
    }
  ],
