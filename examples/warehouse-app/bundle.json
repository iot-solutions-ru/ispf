      "sql": "CREATE TABLE IF NOT EXISTS wh_location (id UUID PRIMARY KEY, location_code VARCHAR(64) NOT NULL, status VARCHAR(32) NOT NULL); INSERT INTO wh_location (id, location_code, status) SELECT 'aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa', 'A-01', 'ready' WHERE NOT EXISTS (SELECT 1 FROM wh_location WHERE location_code = 'A-01'); INSERT INTO wh_location (id, location_code, status) SELECT 'bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb', 'B-02', 'assigned' WHERE NOT EXISTS (SELECT 1 FROM wh_location WHERE location_code = 'B-02');"
    }
  ],
