# BL-159 turnkey three-tier historian profile (hot PG → warm ClickHouse → cold Parquet).
# Prerequisites: ClickHouse reachable (deploy/docker-compose.clickhouse.yml or VPS playbook).

ISPF_HISTORIAN_DEPLOY_PROFILE=three-tier
ISPF_HISTORIAN_TIER_WARM_ENABLED=true

ISPF_VARIABLE_HISTORY_STORE=jdbc
ISPF_VARIABLE_HISTORY_DUAL_WRITE_ENABLED=true

ISPF_HISTORIAN_TIER_HOT_STORE=jdbc
ISPF_HISTORIAN_TIER_HOT_RETENTION_DAYS=7
ISPF_HISTORIAN_TIER_HOT_DUAL_WRITE=true

ISPF_HISTORIAN_TIER_WARM_STORE=clickhouse
ISPF_HISTORIAN_TIER_WARM_RETENTION_DAYS=90

ISPF_VARIABLE_HISTORY_CLICKHOUSE_URL=http://127.0.0.1:8123
ISPF_VARIABLE_HISTORY_CLICKHOUSE_DATABASE=ispf
ISPF_VARIABLE_HISTORY_CLICKHOUSE_TABLE=variable_samples
ISPF_VARIABLE_HISTORY_CLICKHOUSE_USERNAME=default
ISPF_VARIABLE_HISTORY_CLICKHOUSE_PASSWORD=

ISPF_HISTORIAN_TIER_COLD_STORE=cold
ISPF_HISTORIAN_TIER_COLD_RETENTION_DAYS=3650
ISPF_HISTORIAN_TIER_COLD_BUCKET=ispf-historian-archive
ISPF_HISTORIAN_TIER_COLD_PREFIX=variable-samples/
ISPF_HISTORIAN_TIER_COLD_FORMAT=parquet

# Optional nightly Parquet export (local tree or S3-mounted path)
ISPF_HISTORIAN_COLD_ARCHIVE_ENABLED=false
ISPF_HISTORIAN_COLD_ARCHIVE_LOCAL_ROOT=/var/lib/ispf/historian-cold
