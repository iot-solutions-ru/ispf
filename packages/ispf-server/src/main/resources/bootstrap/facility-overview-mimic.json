        { "x": 184, "y": 320 },
        { "x": 320, "y": 320 }
      ],
      "style": { "strokeWidth": 3, "stroke": "var(--border)" }
    },
    {
      "id": "c2",
      "layerId": "layer-default",
      "from": { "elementId": "pump-1", "port": "e" },
      "to": { "elementId": "pump-2", "port": "w" },
      "points": [
        { "x": 384, "y": 320 },
        { "x": 520, "y": 320 }
      ],
      "style": { "strokeWidth": 3, "stroke": "var(--border)" }
    },
    {
      "id": "c3",
      "layerId": "layer-default",
      "from": { "elementId": "pump-2", "port": "e" },
      "to": { "elementId": "valve-2", "port": "w" },
      "points": [
        { "x": 584, "y": 320 },
        { "x": 720, "y": 320 }
      ],
      "style": { "strokeWidth": 3, "stroke": "var(--border)" }
    },
    {
      "id": "c4",
      "layerId": "layer-default",
      "from": { "elementId": "valve-2", "port": "e" },
      "to": { "elementId": "flow", "port": "w" },
      "points": [
        { "x": 784, "y": 320 },
        { "x": 920, "y": 320 }
      ],
      "style": { "strokeWidth": 3, "stroke": "var(--border)" }
    }
  ]
}
