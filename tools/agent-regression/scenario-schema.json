{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ispf.example.invalid/schemas/agent-regression-scenario-v1.json",
  "title": "AgentRegressionScenario",
  "type": "object",
  "required": ["id", "version", "domain", "title", "prompt"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "version": { "type": "string" },
    "domain": { "type": "string", "enum": ["scada", "mes", "hvac"] },
    "lane": {
      "type": "string",
      "enum": ["human", "agent", "both"],
      "description": "human = click-through in web console; agent = AI Studio/tool playbook; both = either"
    },
    "kind": {
      "type": "string",
      "enum": ["platform-primitive"],
      "description": "Platform velocity fixture (not a vertical product scenario)"
    },
    "title": { "type": "string", "minLength": 3 },
    "description": { "type": "string" },
    "prompt": {
      "type": "string",
      "minLength": 10,
      "description": "Natural-language ask a plant engineer / integrator would type (no tool names)"
    },
    "uiJourney": {
      "type": "string",
      "description": "Ordered human path through the web console (Solutions → Explorer → …)"
    },
    "humanSteps": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 },
      "description": "Click-level steps a human can follow without AI Studio"
    },
    "playbook": { "type": "string" },
    "bundle": {
      "type": "object",
      "required": ["appId", "manifestPath"],
      "additionalProperties": false,
      "properties": {
        "appId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "manifestPath": { "type": "string", "minLength": 5 }
      }
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "validateBundle": { "type": "boolean" },
        "requiredTools": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "requiredObjectPaths": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "operatorSurfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "solutions",
              "marketplace",
              "explorer",
              "drivers",
              "dashboard",
              "mimic",
              "operator",
              "alarms",
              "work-queue",
              "schedules",
              "ai-studio"
            ]
          },
          "description": "UI surfaces that must show a successful outcome"
        }
      }
    }
  }
}
