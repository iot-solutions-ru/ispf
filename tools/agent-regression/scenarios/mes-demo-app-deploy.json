{
  "id": "mes-demo-app-deploy",
  "version": "1",
  "domain": "mes",
  "lane": "agent",
  "title": "Demo app deploy (UI verify)",
  "description": "Validate and import demo-app with SQL reports and operator shell.",
  "prompt": "Install the demo application bundle and open its operator screens; run a sample report if available.",
  "uiJourney": "Solutions → Deploy demo → Operator",
  "humanSteps": [
    "Deploy demo from Solutions.",
    "Open /?mode=operator&app=demo and confirm screens."
  ],
  "playbook": "AgentDeployPlaybook",
  "bundle": {
    "appId": "demo",
    "manifestPath": "examples/demo-app/bundle.json"
  },
  "acceptance": {
    "validateBundle": true,
    "requiredTools": [
      "validate_bundle",
      "import_package",
      "run_report"
    ],
    "operatorSurfaces": [
      "solutions",
      "operator"
    ]
  }
}
