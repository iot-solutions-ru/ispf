{
  "id": "mes-marketplace-demo",
  "version": "1",
  "domain": "mes",
  "lane": "both",
  "title": "Marketplace demo install (UI)",
  "description": "Minimal marketplace GA demo bundle for browse → install flow.",
  "prompt": "Install marketplace-demo from Marketplace/Solutions and open its operator UI.",
  "uiJourney": "Marketplace → Deploy → Operator",
  "humanSteps": [
    "Open Marketplace; install marketplace-demo.",
    "Open Operator for marketplace-demo."
  ],
  "playbook": "AgentDeployPlaybook",
  "bundle": {
    "appId": "marketplace-demo",
    "manifestPath": "examples/marketplace-demo/bundle.json"
  },
  "acceptance": {
    "validateBundle": true,
    "requiredTools": [
      "deploy_step_validate",
      "deploy_step_import",
      "configure_operator_ui"
    ],
    "operatorSurfaces": [
      "marketplace",
      "solutions",
      "operator"
    ]
  }
}
