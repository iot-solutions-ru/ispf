{
  "name": "@ispf/web-console",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/copy-legal-assets.mjs && tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:preview": "playwright test --config playwright.preview.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "test:quality": "playwright test --config playwright.quality.config.ts",
    "bundle:budget": "node scripts/bundle-budget.mjs",
    "lighthouse:ci": "node scripts/lighthouse-ci.mjs",
    "quality:gates": "npm run build && npm run bundle:budget && npm run lighthouse:ci && npm run test:quality",
    "pwa:offline-evidence": "node scripts/pwa-offline-evidence.mjs",
    "i18n:check": "node scripts/i18n-check-keys.mjs && node scripts/i18n-check-hardcoded.mjs",
    "i18n:translate": "python ../../tools/i18n/generate-locales.py",
    "import:pid-symbols": "npm run build --prefix ../../tools/symbol-pack-isa",
    "build:pid-symbols": "npm run build --prefix ../../tools/symbol-pack-isa"
  },
  "dependencies": {
    "@codemirror/lang-java": "^6.0.2",
    "@tanstack/react-query": "^5.101.4",
    "@tanstack/react-virtual": "^3.14.8",
    "@uiw/codemirror-theme-vscode": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "bpmn-auto-layout": "^1.3.0",
    "bpmn-js": "^18.21.0",
    "bpmn-moddle": "^10.0.0",
    "cytoscape": "^3.34.0",
    "dompurify": "^3.4.12",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.42.2",
    "i18next": "^26.3.6",
    "maplibre-gl": "^5.6.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.2.8",
    "react-i18next": "^17.0.10",
    "react-map-gl": "^8.0.4",
    "react-router-dom": "^7.6.2",
    "recharts": "^3.10.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "chrome-launcher": "^1.1.2",
    "jsdom": "^29.1.1",
    "lighthouse": "^13.4.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
