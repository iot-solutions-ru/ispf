  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "i18n:check": "node scripts/i18n-check-keys.mjs",
    "i18n:translate": "python ../../tools/i18n/generate-locales.py",
    "import:pid-symbols": "npm run import:pid --prefix ../../tools/symbol-import"
  },
  "dependencies": {
    "@codemirror/lang-java": "^6.0.2",
    "@tanstack/react-query": "^5.64.1",
    "@tanstack/react-virtual": "^3.14.3",
    "@uiw/codemirror-theme-vscode": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "bpmn-auto-layout": "^1.3.0",
    "bpmn-js": "^18.18.0",
    "cytoscape": "^3.34.0",
    "exceljs": "^4.4.0",
    "i18next": "^26.3.1",
    "maplibre-gl": "^5.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.8",
    "react-map-gl": "^8.0.4",
    "react-router-dom": "^7.6.2",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
