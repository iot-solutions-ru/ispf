# Copy to .env and fill in. .env is gitignored — never commit secrets.
ISPF_AI_API_KEY=your-api-key-here
ISPF_AI_PROVIDER=openai-compatible
ISPF_AI_BASE_URL=http://lab-edge.example.invalid:8000/v1
ISPF_AI_MODEL=unsloth/Qwen3.6-35B-A3B-NVFP4

# Lab cluster SSH (key auth — no password in repo)
# One-time: python deploy/local/tools/lab-ssh-install-key.py  (ISPF_LAB_PASSWORD only for first run)
# ISPF_LAB_HOST=lab-edge.example.invalid
# ISPF_LAB_SSH_PORT=22
# ISPF_LAB_USER=lab-operator
# ISPF_LAB_SSH_IDENTITY_FILE=~/.ssh/lab_ed25519
# ISPF_LAB_ADMIN_USER=admin
# ISPF_LAB_ADMIN_PASSWORD=admin
