  "migrations": [
    {
      "id": "itm_integrations_m11_note",
      "sql": "CREATE TABLE IF NOT EXISTS itm_integrations_m11_meta (site_id VARCHAR(64) PRIMARY KEY, note VARCHAR(256)); INSERT INTO itm_integrations_m11_meta (site_id, note) SELECT 'm11', 'LDAP/OPC stubs — configure in metadata' WHERE NOT EXISTS (SELECT 1 FROM itm_integrations_m11_meta WHERE site_id = 'm11');"
    }
  ]
